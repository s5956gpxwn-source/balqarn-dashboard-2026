rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── دوال مساعدة ───
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      // ملاحظة: شرط توثيق البريد مُلغى لأن الحسابات تُنشأ يدوياً من الإدارة
      // ولا يوجد تسجيل ذاتي في التطبيق
      return isSignedIn();
    }
    function isAdmin() {
      return isVerified() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function validStatus(s) {
      return s in ['advanced','regular','pending','stopped','late','stalled','preceipt'];
    }
    function isStringOrMissing(v) {
      return v == null || v is string;
    }
    function isNumberOrMissing(v) {
      return v == null || v is number;
    }

    // ─── دوال تحقق موسّعة (#17) ───
    // السماح بالغياب أو القيمة الفارغة، والتحقق من الصيغة فقط عند وجود قيمة
    function isStrMax(data, key, max) {
      return !(key in data) || (data[key] is string && data[key].size() <= max);
    }
    function isEmailOrEmpty(data, key) {
      return !(key in data) || data[key] == null || data[key] == ''
        || (data[key] is string && data[key].size() <= 200
            && data[key].matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]{2,}$'));
    }
    function isPhoneOrEmpty(data, key) {
      // نتحقق من الطول والصيغة الأساسية (أرقام + مسافات + - + () + +)
      // التحقق الدقيق يبقى في العميل لمرونة الصيغ
      return !(key in data) || data[key] == null || data[key] == ''
        || (data[key] is string && data[key].size() >= 7 && data[key].size() <= 25);
    }
    function isNumInRange(data, key, min, max) {
      return !(key in data) || data[key] == null
        || (data[key] is number && data[key] >= min && data[key] <= max);
    }
    function isPosNumOrMissing(data, key) {
      return !(key in data) || data[key] == null
        || (data[key] is number && data[key] >= 0);
    }

    // ─── المستخدمون ───
    // قراءة وثيقة المستخدم الخاصة بنفسه فقط
    // التعديل محدود بحقلين: theme و printSettings مع تحقق من النوع والحجم
    match /users/{userId} {
      allow read: if isVerified() && request.auth.uid == userId;
      allow update: if isVerified() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['theme','printSettings'])
        && (!('theme' in request.resource.data) || (request.resource.data.theme is string && request.resource.data.theme in ['light','dark']))
        && (!('printSettings' in request.resource.data) || (request.resource.data.printSettings is map && request.resource.data.printSettings.size() < 200));
      // إنشاء وحذف يتمان من الإدارة فقط (Firebase Console أو Admin SDK) — لا من العميل
      allow create, delete: if false;
    }

    // ─── المشاريع ───
    // قراءة: لأي مستخدم موثّق
    // كتابة: للأدمن فقط مع تحقق موسّع من بنية البيانات (#17)
    match /projects/{projectId} {
      allow read: if isVerified();

      allow delete: if isAdmin();

      // التحقق الجوهري + التحقق الموسّع (#17):
      // الحقول الرئيسية: عدد، اسم، حالة، أرقام في نطاقها
      // الحقول النصية الحرة: أطوال قصوى فقط (البيانات قد تأتي من Excel بصيغ متنوعة)
      // الحقول الحساسة (إيميل، جوال): صيغة مبدئية
      allow create, update: if isAdmin()
        && request.resource.data.keys().size() < 200
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 500
        && validStatus(request.resource.data.status)
        && (!('progress' in request.resource.data) || (request.resource.data.progress is number && request.resource.data.progress >= 0 && request.resource.data.progress <= 100))
        && (!('value_num' in request.resource.data) || (request.resource.data.value_num is number && request.resource.data.value_num >= 0))
        // أطوال قصوى لحقول نصية طويلة (ملاحظات، خطابات، وصف)
        && isStrMax(request.resource.data, 'notes', 20000)
        && isStrMax(request.resource.data, 'letters', 20000)
        && isStrMax(request.resource.data, 'description', 10000)
        && isStrMax(request.resource.data, 'project_brief', 10000)
        && isStrMax(request.resource.data, 'last_action', 5000)
        // أطوال معقولة لحقول نصية عادية
        && isStrMax(request.resource.data, 'phase', 500)
        && isStrMax(request.resource.data, 'sub_phase', 500)
        && isStrMax(request.resource.data, 'category', 500)
        && isStrMax(request.resource.data, 'category_sub', 500)
        && isStrMax(request.resource.data, 'contractor', 500)
        && isStrMax(request.resource.data, 'pm', 300)
        && isStrMax(request.resource.data, 'supervisor', 300)
        && isStrMax(request.resource.data, 'consultant', 300)
        && isStrMax(request.resource.data, 'status_raw', 300)
        // التحقق من صيغ الإيميل والجوال
        && isEmailOrEmpty(request.resource.data, 'pm_email')
        && isEmailOrEmpty(request.resource.data, 'contractor_email')
        && isPhoneOrEmpty(request.resource.data, 'pm_phone')
        && isPhoneOrEmpty(request.resource.data, 'contractor_phone')
        && isPhoneOrEmpty(request.resource.data, 'consultant_phone')
        && isPhoneOrEmpty(request.resource.data, 'dept_manager_phone')
        // نطاقات منطقية للحقول الرقمية (نسب مئوية ومدد)
        && isNumInRange(request.resource.data, 'tax_pct', -100, 1000)
        && isNumInRange(request.resource.data, 'increase_pct', -100, 1000)
        && isNumInRange(request.resource.data, 'discount_pct', -100, 1000)
        && isNumInRange(request.resource.data, 'elapsed_pct', -100, 10000)
        && isNumInRange(request.resource.data, 'elapsed_ext_pct', -100, 10000)
        && isNumInRange(request.resource.data, 'delay_pct', -100, 10000)
        && isNumInRange(request.resource.data, 'duration_days', 0, 100000)
        && isNumInRange(request.resource.data, 'duration_after_ext', 0, 100000)
        && isNumInRange(request.resource.data, 'correction_days', -100000, 100000)
        && isNumInRange(request.resource.data, 'stops', 0, 10000)
        && isNumInRange(request.resource.data, 'warnings_count', 0, 10000)
        && isPosNumOrMissing(request.resource.data, 'value_adjusted')
        && isPosNumOrMissing(request.resource.data, 'boq_value')
        && isPosNumOrMissing(request.resource.data, 'guarantee_value')
        && isPosNumOrMissing(request.resource.data, 'advance_payment');
    }

    // ─── بيانات وصفية ───
    // hiddenFields: قائمة نصوص (ميزة UI فقط — ليست أمناً حقيقياً)
    // lastUpdate: ختم زمني نصي
    match /meta/{docId} {
      allow read: if isVerified();
      allow write: if isAdmin()
        && request.resource.data.keys().size() < 20
        && (!('fields' in request.resource.data) || (request.resource.data.fields is list && request.resource.data.fields.size() < 200))
        && (!('timestamp' in request.resource.data) || request.resource.data.timestamp is string);
    }
  }
}
